# =====================================================================
# AptlyAble — example environment variables
# Copy to .env (NOT checked in) and fill in your values.
# Never commit real secrets. Real provider API keys live in AWS Secrets Manager.
# =====================================================================

# ---- Frontend (Next.js) ----
# Public URL of the deployed API (output by `cdk deploy`).
NEXT_PUBLIC_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com

# ---- AWS ----
AWS_REGION=us-east-1
S3_BUCKET_NAME=aptlyable-audio-transcripts
JOBS_TABLE_NAME=aptlyable-transcription-jobs
TRANSCRIPTION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/aptlyable-transcription-queue

# ---- Transcription provider secrets (Secrets Manager IDs, not the keys themselves) ----
DEEPGRAM_SECRET_NAME=aptlyable/deepgram/api-key
OPENAI_SECRET_NAME=aptlyable/openai/api-key
ASSEMBLYAI_SECRET_NAME=aptlyable/assemblyai/api-key

# Twilio integration (recording webhook). Account SID is sent on every
# Twilio webhook so we don't need to store it. Only the auth token lives here.
TWILIO_SECRET_NAME=aptlyable/twilio/auth-token

# Default provider when the client doesn't specify one. deepgram | openai | assemblyai
DEFAULT_PROVIDER=deepgram

# ---- Upload limits ----
# This single var drives the cap in three places:
#   - the CDK stack (passed to API Lambda env)
#   - the API validation
#   - the Next.js build (via next.config.js → NEXT_PUBLIC_MAX_FILE_SIZE_MB)
# Keep it as one number so the UI can't promise a cap the API rejects.
MAX_FILE_SIZE_MB=250
PRESIGNED_UPLOAD_EXPIRES_SECONDS=900
PRESIGNED_DOWNLOAD_EXPIRES_SECONDS=900

# ---- Worker ----
WORKER_CONCURRENCY=3
SQS_WAIT_TIME_SECONDS=20
SQS_MAX_MESSAGES=5
SQS_VISIBILITY_TIMEOUT_SECONDS=1800

# ---- Provider models ----
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en
OPENAI_MODEL=gpt-4o-transcribe
# OPENAI_LANGUAGE=en   # leave unset for auto-detect
ASSEMBLYAI_MODEL=universal
ASSEMBLYAI_LANGUAGE=en

# ---- API CORS ----
# Comma-separated list of allowed origins for the API.
ALLOWED_ORIGINS=http://localhost:3000

# ---- CDK / deployment ----
# Tag value applied to every resource (Cost Explorer / IAM filtering).
ENVIRONMENT=mvp
